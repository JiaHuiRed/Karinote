{
  "name": "redpar",
  "version": "0.0.3",
  "private": true,
  "description": "RedPar — 你的数字人桌宠伙伴",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173; $env:NODE_ENV='development'; node scripts/electron-patch.js .\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "build": "npm run build:renderer && npm run build:main",
    "start": "node scripts/electron-patch.js .",
    "setup": "npx tsx scripts/download-model.mts"
  },
  "dependencies": {
    "@pixi/core": "^7.4.3",
    "@pixi/display": "^7.4.3",
    "pixi-live2d-display": "^0.5.0-beta",
    "pixi.js": "^7.3.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "wait-on": "^7.2.0"
  }
}
